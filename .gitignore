# ==========================================
# MkDocs & Static Site Outputs
# ==========================================
# Exclude the local build directory generated by 'mkdocs serve' or 'mkdocs build'
site/
# Exclude the mandatory GitLab Pages deployment artifact folder if built locally
public/

# ==========================================
# Python & Virtual Environments
# ==========================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Local virtual environments
venv/
.venv/
env/
.env
ENV/

# Pip log files and temporary dependencies packaging
pip-log.txt
pip-delete-this-directory.txt
.cache/

# ==========================================
# Editor & IDE Specific Files
# ==========================================
# VS Code configurations
.vscode/
!.vscode/extensions.json

# JetBrains / PyCharm configurations
.idea/

# OS-specific system files
.DS_Store
Thumbs.db